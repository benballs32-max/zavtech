---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch about modded hardware, software tools, or commissions. Norwich, UK — local collection available.">
  <section class="contact-page">
    <div class="container contact-inner">

      <span class="section-label">// 01 — GET IN TOUCH</span>
      <h1>Contact</h1>
      <p class="contact-intro">
        Direct email only. No ticket system, no chatbot, no contact form that disappears into a void. You email me, I reply.
      </p>

      <div class="contact-grid">
        <div class="contact-main">
          <div class="contact-card">
            <span class="section-label">// EMAIL</span>
            <a href="mailto:hello@zavtech.net" class="email-link">
              hello@zavtech.net
            </a>
            <a href="mailto:hello@zavtech.net" class="btn btn-primary contact-btn">
              SEND EMAIL →
            </a>
            <p class="contact-note font-mono">
              // Opens your email client with the address pre-filled.
            </p>
          </div>

          <div class="contact-card">
            <span class="section-label">// WHAT TO INCLUDE</span>
            <ul class="what-to-include font-mono">
              <li>
                <span class="item-label text-cyan">Hardware enquiries</span>
                Which product you're interested in, whether you want shipping or Norwich collection, any questions about spec or condition.
              </li>
              <li>
                <span class="item-label text-cyan">Commission builds</span>
                What you're trying to achieve, rough budget (hardware only, or including build time), form factor preference, OS/software preference.
              </li>
              <li>
                <span class="item-label text-cyan">Software</span>
                Which tool, any pre-purchase questions, or post-purchase issues.
              </li>
            </ul>
          </div>
        </div>

        <aside class="contact-sidebar">
          <div class="sidebar-card">
            <span class="section-label">// LOCATION</span>
            <p class="font-mono" style="font-size: 0.8rem; color: var(--text);">Norwich, UK</p>
            <p class="font-mono" style="font-size: 0.75rem; color: var(--muted); margin-top: 0.5rem;">
              // Local collection available for all hardware. No extra charge.
            </p>
          </div>

          <div class="sidebar-card">
            <span class="section-label">// RESPONSE TIME</span>
            <p class="font-mono" style="font-size: 0.75rem; color: var(--muted);">
              // Usually same day or next day. I'm not running a business with SLAs — but I do actually reply.
            </p>
          </div>

          <div class="sidebar-card">
            <span class="section-label">// NOT SURE WHAT TO ASK?</span>
            <p class="font-mono" style="font-size: 0.75rem; color: var(--muted); margin-bottom: 1rem;">
              // Browse the shop first — most common questions are answered on the product pages.
            </p>
            <a href="/shop" class="btn btn-outline" style="font-size: 0.75rem; padding: 0.6rem 1.2rem;">BROWSE SHOP →</a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-page {
    padding: 5rem 0;
  }

  .contact-inner h1 {
    margin: 0.5rem 0 1.5rem;
  }

  .contact-intro {
    color: var(--muted);
    font-size: 1rem;
    max-width: 560px;
    margin-bottom: 3rem;
    line-height: 1.7;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    align-items: start;
  }

  .contact-main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-card {
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
  }

  .email-link {
    font-family: var(--font-crt);
    font-size: 2rem;
    color: var(--neon-blue);
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: color 0.2s, text-shadow 0.2s;
    line-height: 1;
    text-shadow: 0 0 15px var(--neon-blue), 0 0 30px rgba(0, 229, 255, 0.4);
    animation: neon-flicker 4s ease-in-out infinite;
  }

  .email-link:hover {
    color: var(--neon-pink);
    text-shadow: 0 0 15px var(--neon-pink), 0 0 30px rgba(255, 45, 149, 0.5);
  }

  .contact-btn {
    align-self: flex-start;
  }

  .contact-note {
    font-size: 0.72rem;
    color: var(--muted);
  }

  /* What to include list */
  .what-to-include {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .what-to-include li {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.6;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .what-to-include li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .item-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Sidebar */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
  }

  .sidebar-card {
    background: var(--panel);
    border: 1px solid var(--border);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 0 100%);
  }

  .sidebar-card .section-label {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-sidebar {
      position: static;
    }
  }
</style>
