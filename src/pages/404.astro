---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Not Found">
  <section class="not-found">
    <div class="container">
      <span class="section-label">// ERROR</span>
      <h1 class="error-code font-crt">404</h1>
      <p class="error-msg font-mono">// PAGE NOT FOUND</p>
      <p class="error-sub">That page doesn't exist. Might have been moved, deleted, or you took a wrong turn.</p>
      <a href="/" class="btn btn-primary">← BACK HOME</a>
    </div>
  </section>
</Base>

<style>
  .not-found {
    padding: 8rem 0;
    text-align: center;
  }

  .error-code {
    font-size: 8rem;
    color: var(--cyan);
    line-height: 1;
    margin: 1rem 0 0.5rem;
    text-shadow: 0 0 40px rgba(0, 245, 255, 0.3);
    animation: flicker 6s ease-in-out infinite;
  }

  .error-msg {
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .error-sub {
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 400px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }
</style>
