---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products } from '../../data/products.js';

export function getStaticPaths() {
  return products.map(p => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

const { product } = Astro.props;
const { name, category, price, status, tags, full_desc, image } = product;

const related = products
  .filter(p => p.slug !== product.slug && p.category === category)
  .slice(0, 3);

const statusLabel = status === 'available' ? 'IN STOCK' : status === 'sold' ? 'SOLD' : 'ENQUIRE';
const enquireSubject = encodeURIComponent(`Enquiry: ${name}`);
const enquireBody = encodeURIComponent(`Hi,\n\nI'm interested in the ${name} (${price}).\n\n`);
const mailtoHref = `mailto:hello@zavtech.net?subject=${enquireSubject}&body=${enquireBody}`;

// Convert markdown-style bold to HTML
const descHtml = full_desc
  .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
  .split('\n')
  .map(line => line.trim())
  .filter(line => line.length > 0)
  .map(line => line.startsWith('- ') ? `<li>${line.slice(2)}</li>` : `<p>${line}</p>`)
  .join('\n')
  .replace(/(<li>[\s\S]*?<\/li>(\n|$))+/g, match => `<ul>${match}</ul>`);
---

<Base title={name} description={product.short_desc}>
  <div class="product-page">
    <div class="container">

      <nav class="breadcrumb font-mono" aria-label="Breadcrumb">
        <a href="/shop">← SHOP</a>
        <span class="text-muted">/</span>
        <span class="text-muted">{name}</span>
      </nav>

      <div class="product-layout">
        <!-- Image -->
        <div class="product-image-wrap">
          <div class="product-image">
            <img
              src={image}
              alt={name}
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
            />
            <div class="image-placeholder" style="display:none">
              <svg width="64" height="64" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="8" width="40" height="32" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="17" cy="20" r="4" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M4 36l10-10 8 8 8-10 14 12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none"/>
              </svg>
              <span class="font-mono">{name}</span>
            </div>
          </div>
        </div>

        <!-- Details -->
        <div class="product-details">
          <div class="product-meta">
            <span class={`status status--${status}`}>{statusLabel}</span>
            <span class="font-mono text-muted" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em">{category}</span>
          </div>

          <h1 class="product-name">{name}</h1>

          <div class="product-price-row">
            <span class="price">{price}</span>
          </div>

          <div class="product-tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>

          <div class="product-actions">
            {status !== 'sold' ? (
              <a href={mailtoHref} class="btn btn-primary">
                {status === 'enquire' ? '[ ENQUIRE → ]' : '[ BUY / ENQUIRE → ]'}
              </a>
            ) : (
              <span class="btn btn-outline" style="opacity:0.4;pointer-events:none">SOLD OUT</span>
            )}
          </div>

          <p class="contact-note font-mono">
            // Direct email — <a href="mailto:hello@zavtech.net">hello@zavtech.net</a>. No ticket system.
          </p>
        </div>
      </div>

      <!-- Full description -->
      <div class="product-description">
        <span class="section-label">// DETAILS</span>
        <div class="desc-content" set:html={descHtml} />
      </div>

      <!-- Related products -->
      {related.length > 0 && (
        <div class="related">
          <span class="section-label">// RELATED</span>
          <div class="related-grid">
            {related.map(p => <ProductCard {...p} />)}
          </div>
        </div>
      )}

    </div>
  </div>
</Base>

<style>
  .product-page {
    padding: 3rem 0 5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    margin-bottom: 3rem;
    color: var(--muted);
  }

  .breadcrumb a {
    color: var(--cyan);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--magenta);
  }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 4rem;
  }

  /* Image */
  .product-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--darker);
    border: 1px solid var(--border);
    clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
    overflow: hidden;
    position: relative;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Details */
  .product-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .product-name {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: 1.25rem;
    color: var(--text);
  }

  .product-price-row {
    margin-bottom: 1.25rem;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2rem;
  }

  .product-actions {
    margin-bottom: 1.25rem;
  }

  .contact-note {
    font-size: 0.72rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .contact-note a {
    color: var(--cyan);
  }

  /* Description */
  .product-description {
    max-width: 720px;
    margin-bottom: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .desc-content {
    margin-top: 1.25rem;
  }

  .desc-content :global(p) {
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .desc-content :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .desc-content :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .desc-content :global(li) {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    padding-left: 1rem;
    position: relative;
  }

  .desc-content :global(li)::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--cyan);
  }

  /* Related */
  .related {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  @media (max-width: 768px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
