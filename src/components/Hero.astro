---
interface Props {
  headline: string;
  sub: string;
  cta1?: { href: string; label: string };
  cta2?: { href: string; label: string };
  label?: string;
}

const {
  headline,
  sub,
  cta1 = { href: '/shop', label: '[ VIEW SHOP → ]' },
  cta2 = { href: '/contact', label: '[ CONTACT → ]' },
  label = '// 00 — ZAVTECH.NET',
} = Astro.props;
---

<section class="hero">
  <div class="container hero-inner">
    <span class="section-label">{label}</span>

    <h1 class="hero-headline" set:html={headline} />

    <p class="hero-sub">{sub}</p>

    <div class="hero-ctas">
      <a href={cta1.href} class="btn btn-primary">{cta1.label}</a>
      <a href={cta2.href} class="btn btn-outline">{cta2.label}</a>
    </div>

    <div class="hero-status font-mono">
      <span class="status-dot"></span>
      <span>SYSTEMS ONLINE — NORWICH, UK</span>
    </div>
  </div>

  <div class="hero-decoration" aria-hidden="true">
    <div class="corner corner--tl"></div>
    <div class="corner corner--br"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 7rem 0 6rem;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 5%;
    right: -20%;
    width: 800px;
    height: 800px;
    background:
      radial-gradient(circle at 30% 30%, rgba(0, 229, 255, 0.12) 0%, transparent 45%),
      radial-gradient(circle at 70% 50%, rgba(255, 45, 149, 0.08) 0%, transparent 45%);
    pointer-events: none;
    filter: blur(60px);
    animation: pulse-glow 6s ease-in-out infinite;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero-headline {
    margin: 0.5rem 0 1.5rem;
    color: var(--text);
    text-shadow: 0 0 30px rgba(0, 229, 255, 0.2);
  }

  .hero-headline :global(.accent) {
    color: var(--neon-blue);
    text-shadow: 0 0 15px var(--neon-blue), 0 0 30px rgba(0, 229, 255, 0.5), 0 0 50px rgba(0, 229, 255, 0.3);
    animation: neon-blink 3s ease-in-out infinite;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 560px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .hero-status {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: #00ff88;
    border-radius: 50%;
    box-shadow: 0 0 8px #00ff88, 0 0 16px rgba(0, 255, 136, 0.6), 0 0 24px rgba(0, 255, 136, 0.3);
    animation: neon-flicker 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .hero-decoration {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .corner {
    position: absolute;
    width: 40px;
    height: 40px;
  }

  .corner--tl {
    top: 1.5rem;
    left: 1.5rem;
    border-top: 2px solid var(--border);
    border-left: 2px solid var(--border);
  }

  .corner--br {
    bottom: 1.5rem;
    right: 1.5rem;
    border-bottom: 2px solid var(--border);
    border-right: 2px solid var(--border);
  }
</style>
